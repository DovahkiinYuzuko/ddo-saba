# DDO Saba Nginx Configuration for Windows

events { worker_connections 1024; }

http {
    include       mime.types;
    default_type  application/octet-stream;

    # Limit maximum concurrent connections to Ollama inference
    limit_conn_zone $binary_remote_addr zone=ollama_limit:10m;

    # Dynamic map-based token verification
    map_hash_bucket_size 64;
    map $http_x_ddo_token $auth_status {
        "__DDO_SABA_TOKEN__" "ok";
        default "fail";
    }

    server {
        listen       8088;
        server_name  localhost;

        # Security Headers (applied globally to this server block)
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;

        # Static Web UI distribution
        location / {
            root   html;
            index  index.html;
            try_files $uri $uri/ /index.html;

            # Strict CSP for static assets (API endpoints use wildcard CORS instead)
            add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http: https: ws: wss:;" always;
        }

        # Local PowerShell Broadcast Proxy: Poll
        location /api/poll {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/poll;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Broadcast
        location /api/broadcast {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/broadcast;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: History
        location /api/history {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/history;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Model Sync
        location /api/model {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/model;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Queue
        location /api/queue {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/queue;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Usage Log
        location /api/usage {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/usage;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Ollama API Proxy (inference: chat)
        location /api/chat {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            limit_conn ollama_limit 3;
            proxy_pass http://127.0.0.1:11434/api/chat;
            # Fix: Use 'localhost' to pass Ollama's internal origin check (avoids 403 via Cloudflare Tunnel)
            proxy_set_header Host localhost;
            proxy_set_header X-Real-IP $remote_addr;

            # Streaming integrity: disable buffering for LLM chunk transfer
            proxy_buffering off;
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # 24h Timeouts for long reasoning
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama API Proxy (generate: pre-load)
        location /api/generate {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            limit_conn ollama_limit 3;
            proxy_pass http://127.0.0.1:11434/api/generate;
            # Fix: Use 'localhost' to pass Ollama's internal origin check
            proxy_set_header Host localhost;
            proxy_set_header X-Real-IP $remote_addr;

            # Streaming integrity: disable buffering for preload progress
            proxy_buffering off;
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # 24h Timeouts for long model preload
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama system status and model lists
        location /api/tags {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:11434/api/tags;
            # Fix: Use 'localhost' to pass Ollama's internal origin check
            proxy_set_header Host localhost;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Ollama VRAM usage status
        location /api/ps {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:11434/api/ps;
            # Fix: Use 'localhost' to pass Ollama's internal origin check
            proxy_set_header Host localhost;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}
