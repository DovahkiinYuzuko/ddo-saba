# DDO Saba Nginx Configuration for Windows

events { worker_connections 1024; }

http {
    include       mime.types;
    default_type  application/octet-stream;

    # Limit maximum concurrent connections to Ollama inference
    limit_conn_zone $binary_remote_addr zone=ollama_limit:10m;

    # Dynamic map-based token verification
    map_hash_bucket_size 64;
    map $http_x_ddo_token $auth_status {
        "__DDO_SABA_TOKEN__" "ok";
        default "fail";
    }

    server {
        listen       8088;
        server_name  localhost;

        # Static Web UI distribution
        location / {
            root   html;
            index  index.html;
            try_files $uri $uri/ /index.html;
        }

        # Local PowerShell Broadcast Proxy: Poll
        location /api/poll {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/poll;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Broadcast
        location /api/broadcast {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/broadcast;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: History
        location /api/history {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/history;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Local PowerShell Broadcast Proxy: Model Sync
        location /api/model {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:8089/api/model;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Ollama API Proxy (inference: chat)
        location /api/chat {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            limit_conn ollama_limit 1;
            proxy_pass http://127.0.0.1:11434/api/chat;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            
            # 24h Timeouts for long reasoning
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama API Proxy (generate: pre-load)
        location /api/generate {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            limit_conn ollama_limit 1;
            proxy_pass http://127.0.0.1:11434/api/generate;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            
            # 24h Timeouts for long model preload
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama system status and model lists
        location /api/tags {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:11434/api/tags;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Ollama VRAM usage status
        location /api/ps {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token" always;

            if ($request_method = OPTIONS) {
                return 204;
            }

            if ($auth_status = "fail") {
                return 403;
            }

            proxy_pass http://127.0.0.1:11434/api/ps;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}
