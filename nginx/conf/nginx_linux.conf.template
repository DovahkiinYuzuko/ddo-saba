# DDO Saba Nginx Configuration for Linux

# Load NJS module dynamically (path substituted on startup)
load_module __NJS_SO__;

events { worker_connections 1024; }

# Environment variable for access authentication (set by host script)
env DDO_SABA_TOKEN;

http {
    include       mime.types;
    default_type  application/octet-stream;
    
    # Shared memory zone for temporary broadcast. Key expires in 30s.
    js_shared_dict_zone zone=broadcast_zone:1M timeout=30s;
    
    # Import njs script
    js_import conf/broadcast.js;

    # Limit maximum concurrent connections to Ollama inference
    limit_conn_zone $binary_remote_addr zone=ollama_limit:10m;

    server {
        listen       8088;
        server_name  localhost;

        # Security Headers (applied globally to this server block)
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;

        # Static Web UI distribution
        location / {
            root   html;
            index  index.html;
            try_files $uri $uri/ /index.html;

            # Strict CSP for static assets (API endpoints use wildcard CORS instead)
            add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http: https: ws: wss:;" always;
        }

        # Nginx JS (njs) Poll endpoint
        location /api/poll {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.get_message;
        }

        # Nginx JS (njs) Broadcast endpoint
        location /api/broadcast {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.post_message;
        }

        # Nginx JS (njs) History endpoint
        location /api/history {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.get_history;
        }

        # Nginx JS (njs) Model Sync endpoint
        location /api/model {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.handle_model;
        }

        # Nginx JS (njs) Queue Sync
        location /api/queue {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
            add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                add_header Access-Control-Expose-Headers "X-DDO-Active-Count" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.handle_queue;
        }

        # Nginx JS (njs) Usage Log endpoint
        location /api/usage {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                return 204;
            }

            auth_request /auth_check;
            js_content broadcast.handle_usage;
        }

        # Auth subrequest checker
        location = /auth_check {
            internal;
            js_content broadcast.auth_check;
        }

        # Ollama API Proxy (inference: chat)
        location /api/chat {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                return 204;
            }

            auth_request /auth_check;
            limit_conn ollama_limit 3;
            proxy_pass http://127.0.0.1:11434/api/chat;
            # Fix: Use original $host to pass Ollama's port checks
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;

            # Streaming integrity: disable buffering for LLM chunk transfer
            proxy_buffering off;
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # 24h Timeouts for long reasoning
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama API Proxy (generate: pre-load)
        location /api/generate {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                return 204;
            }

            auth_request /auth_check;
            limit_conn ollama_limit 3;
            proxy_pass http://127.0.0.1:11434/api/generate;
            # Fix: Use original $host to pass Ollama's port checks
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;

            # Streaming integrity: disable buffering for preload progress
            proxy_buffering off;
            proxy_http_version 1.1;
            proxy_set_header Connection "";

            # 24h Timeouts for long model preload
            proxy_read_timeout 86400s;
            proxy_connect_timeout 86400s;
            proxy_send_timeout 86400s;
        }

        # Ollama system status and model lists
        location /api/tags {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                return 204;
            }

            auth_request /auth_check;
            proxy_pass http://127.0.0.1:11434/api/tags;
            # Fix: Use original $host to pass Ollama's port checks
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        # Ollama VRAM usage status
        location /api/ps {
            add_header Access-Control-Allow-Origin * always;
            add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;

            if ($request_method = OPTIONS) {
                add_header Access-Control-Allow-Origin * always;
                add_header Access-Control-Allow-Methods "POST, GET, OPTIONS" always;
                add_header Access-Control-Allow-Headers "Content-Type, X-DDO-Token, X-DDO-Username, X-DDO-Client-Id, X-DDO-Since-Id, x-ddo-client-id, x-ddo-since-id" always;
                return 204;
            }

            auth_request /auth_check;
            proxy_pass http://127.0.0.1:11434/api/ps;
            # Fix: Use original $host to pass Ollama's port checks
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }
    }
}
