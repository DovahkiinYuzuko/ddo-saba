*

!.gitignore

# Docs variables and functions only
!docs/
!docs/variables'n'functions/
!docs/variables'n'functions/**

# Start scripts
!init_server.bat
!init_server.sh
!bin/
!bin/**
bin/*.pid
bin/*.exe
bin/cloudflared

# Nginx config and scripts
!nginx/
nginx/html/
nginx/temp/
nginx/logs/

# Web UI source files
!web-ui/
!web-ui/package.json
!web-ui/package-lock.json
!web-ui/scripts/
!web-ui/scripts/**
!web-ui/src/
!web-ui/src/**
web-ui/src/assets

