*

!.gitignore

# Docs variables and functions only
!docs/
!docs/variables'n'functions/
!docs/variables'n'functions/**

# Start scripts
!start_server.bat
!start_server.sh
!stop_server.bat
!stop_server.sh
!bin/
!bin/**

# Nginx config and scripts
!nginx/
nginx/html/
nginx/temp/
nginx/logs/

# Web UI source files
!web-ui/
!web-ui/src/
!web-ui/src/**
web-ui/src/assets

